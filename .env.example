# ── Anthropic API ──────────────────────────────────────────────────────────────
# Required for ATS scoring. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── CV ─────────────────────────────────────────────────────────────────────────
# Path to your CV as plain text. Relative paths are resolved from the backend/
# directory. Default: ../cv.txt (project root).
CV_PATH=../cv.txt

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Default: ./data/jobs.db (inside backend/).
DB_PATH=./data/jobs.db

# ── Candidate profile (ATS scoring) ───────────────────────────────────────────
# These values are injected into the scoring prompt sent to Claude.
# Edit them to match your own situation.
CANDIDATE_LOCATION=Your City, Country
CANDIDATE_MAX_COMMUTE_MIN=45
CANDIDATE_LANGUAGE_REQUIREMENT=Language B1

# ── Job search ─────────────────────────────────────────────────────────────────
# Roles and location passed to scrapers. Comma-separated list for roles.
# Edit backend/app/config.py for more advanced configuration.
# SEARCH_ROLES=["AI Engineer","Data Engineer","Analytics Engineer"]
# SEARCH_LOCATION=Germany
# MAX_JOBS_PER_SOURCE=50
